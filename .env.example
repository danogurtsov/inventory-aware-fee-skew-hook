# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.

# Ethereum mainnet RPC endpoint, used only by the fork tests (test/fork/).
# Any mainnet provider works (dRPC, Alchemy, Infura, QuickNode, your own node).
# The unit, invariant and simulation tests do NOT need this — they run fully offline.
ETH_RPC_URL=https://your-ethereum-mainnet-rpc-endpoint
